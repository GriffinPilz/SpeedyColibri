# Keep the Docker build context small and free of secrets/large artifacts.
.git/
target/
**/target/

# model weights & run artifacts (mounted at runtime, never baked in)
*.safetensors
*.coli_kv
*.coli_usage
.coli-cache/
c/glm_tiny*/
c/glm_bench*/
c/bench/

# python caches
**/__pycache__/
*.pyc
c/mio_env/

# editor / OS cruft
*.rs.bk
.DS_Store
